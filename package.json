{
  "name": "polarhub-mcp-client",
  "version": "1.0.0",
  "type": "module",
  "description": "PolarHub MCP Client - Independent web application for PolarHub MCP Server",
  "main": "./dist/index.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --ignore './packages/frontend/**' src/index.ts",
    "build": "npm run build -w @polarhub-demo/frontend && tsc",
    "start": "NODE_ENV=production node dist/index.js",
    "clean": "rm -rf dist packages/*/dist packages/*/node_modules node_modules"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "dotenv": "^16.3.1",
    "eventsource": "^4.1.0",
    "express": "^4.21.0",
    "openai": "^4.28.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
