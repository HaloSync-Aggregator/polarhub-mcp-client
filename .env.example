# =============================================================================
# PolarHub MCP Client - Environment Configuration
# =============================================================================
#
# Quick Setup / 빠른 설정:
#   1. cp .env.example .env
#   2. Fill in the 3 REQUIRED sections below (LLM key + MCP server + PolarHub credentials)
#   3. npm install && npm run dev
#   4. Open http://localhost:3000
#
# ⚠️  .env is in .gitignore — never commit secrets to Git.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. LLM Provider  (REQUIRED — pick ONE)
#    LLM 제공자 (필수 — 하나만 선택)
# -----------------------------------------------------------------------------
# Choose: openai | gemini | bedrock
LLM_PROVIDER=gemini

# --- Option A: Google Gemini (recommended for quick start) ---
# Get your key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash

# --- Option B: OpenAI ---
# Get your key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4-turbo-preview

# --- Option C: AWS Bedrock ---
# BEDROCK_API_KEY=your-bedrock-bearer-token
# AWS_REGION=us-east-1
# BEDROCK_MODEL=anthropic.claude-3-sonnet-20240229-v1:0


# -----------------------------------------------------------------------------
# 2. MCP Server Connection  (REQUIRED)
#    MCP 서버 연결 (필수)
# -----------------------------------------------------------------------------
# Default: AgentCore Gateway — HMAC auth is handled automatically.
# 기본값: AgentCore Gateway — HMAC 인증이 자동으로 처리됩니다.
MCP_SERVER_URL=https://mcp.sandbox.halo-platform.net/mcp
MCP_GATEWAY_HMAC_ENABLED=true
# MCP_GATEWAY_AGENCY_ID=          # Falls back to POLARHUB_TENANT_ID if not set

# For local MCP server development:
# 로컬 MCP 서버 개발 시:
# MCP_SERVER_URL=http://localhost:8000/mcp
# MCP_GATEWAY_HMAC_ENABLED=false


# -----------------------------------------------------------------------------
# 3. PolarHub API Credentials  (REQUIRED)
#    PolarHub API 인증 정보 (필수)
# -----------------------------------------------------------------------------
# These are passed to the MCP server as X-PolarHub-* HTTP headers.
# MCP 서버에 X-PolarHub-* HTTP 헤더로 전달됩니다.
#
# How to get credentials / 인증 정보 발급:
#   → Sign up at https://halosync.kr
#   → API docs: https://doc.halo-platform.net
#   → Or contact PolarHub admin for sandbox access
#
POLARHUB_API_BASE_URL=https://polarhub.sandbox.halo-platform.net
POLARHUB_TENANT_ID=your-tenant-id
POLARHUB_API_SECRET=your-base64-encoded-secret


# -----------------------------------------------------------------------------
# 4. Optional Settings
#    선택 설정
# -----------------------------------------------------------------------------
# PORT=3000                        # Server port (default: 3000)
# POLARHUB_SITE_CODE=01            # Site code (default: 01)
# POLARHUB_AGENCY_CONTACT_ID=CTC_TA1  # Agency contact ID
# DEBUG_PROMPTS=true               # Print LLM prompts to console
